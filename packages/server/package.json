    "@types/global-agent": "2.1.1",
    "@types/html-to-text": "^9.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/koa": "3.0.1",
    "@types/koa-send": "^4.1.6",
    "@types/koa__cors": "5.0.0",
    "@types/lodash": "4.14.200",
    "@types/mailparser": "^3.4.6",
    "@types/mssql": "9.1.5",
    "@types/node-fetch": "2.6.4",
    "@types/oracledb": "6.5.1",
    "@types/pg": "8.6.6",
    "@types/semver": "7.3.7",
    "@types/supertest": "2.0.14",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/tmp": "0.2.6",
    "@types/uuid": "8.3.4",
    "copyfiles": "2.4.1",
    "docker-compose": "1.2.0",
    "ioredis-mock": "8.9.0",
    "jest-extended": "^4.0.2",
    "jest-mock": "^30.0.5",
    "jest-openapi": "0.14.2",
    "nock": "13.5.4",
    "nodemon": "2.0.15",
    "openapi-typescript": "7.10.1",
    "rimraf": "3.0.2",
    "supertest": "6.3.3",
    "swagger-jsdoc": "6.1.0",
    "timekeeper": "2.2.0",
    "ts-node": "10.8.1",
    "zod": "^4.2.1"
  },
  "nx": {
    "targets": {
      "build": {
        "inputs": [
          "default",
          "{projectRoot}/src",
          "{projectRoot}/builder",
          "{projectRoot}/client",
          "{projectRoot}/scripts",
          "{projectRoot}/package.json",
          "{projectRoot}/tsconfig*.json"
        ],
        "outputs": [
          "{projectRoot}/builder",
          "{projectRoot}/client",
          "{projectRoot}/dist"
        ],
        "dependsOn": [
          {
            "projects": [
              "@budibase/client",
              "@budibase/builder"
            ],
            "target": "build"
          }
        ]
      }
    }
  }
}
