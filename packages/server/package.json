    "@koa/cors": "5.0.0",
    "@koa/router": "15.3.0",
    "@socket.io/redis-adapter": "^8.2.1",
    "@types/xml2js": "^0.4.14",
    "ai": "^6.0.116",
    "airtable": "0.12.2",
    "arangojs": "7.2.0",
    "archiver": "7.0.1",
    "bcrypt": "6.0.0",
    "bson": "^6.9.0",
