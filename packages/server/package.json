    "html-to-text": "^9.0.5",
    "http-graceful-shutdown": "^3.1.12",
    "imapflow": "^1.1.0",
    "ioredis": "5.3.2",
    "isolated-vm": "^6.0.1",
    "joi": "17.6.0",
    "js-yaml": "4.1.1",
    "jsonschema": "1.4.0",
    "jsonwebtoken": "9.0.2",
    "knex": "2.4.2",
    "koa": "3.1.2",
    "koa-body": "7.0.1",
    "koa-compress": "4.0.1",
    "koa-send": "5.0.1",
    "koa-useragent": "^4.1.0",
    "koa2-ratelimit": "1.1.3",
    "lodash": "4.18.1",
