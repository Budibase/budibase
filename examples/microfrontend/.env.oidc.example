# Required for OIDC mode
OIDC_ISSUER=replace-with-your-oidc-issuer
OIDC_CLIENT_ID=replace-with-your-oidc-client-id
OIDC_CLIENT_SECRET=replace-with-your-oidc-client-secret

# Optional overrides
OIDC_SCOPES=openid profile email
OIDC_REDIRECT_URI=http://localhost:5174/auth/callback
BUDIBASE_TENANT_ID=default
BUDIBASE_OIDC_CONFIG_ID=
BFF_SESSION_TTL_MS=28800000
HOST_PORT=5173
BFF_PORT=5174
HOST_ORIGIN=http://localhost:5173
BUDIBASE_ORIGIN=http://localhost:10000
BFF_PUBLIC_ORIGIN=http://localhost:5174
